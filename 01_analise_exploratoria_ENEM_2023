        "db_filtro = pd.read_csv('/content/drive/MyDrive/Projeto_ENEM/MICRODADOS_ENEM_2023.csv', sep=';', chunksize=10000, encoding='latin-1', usecols=['TP_FAIXA_ETARIA','TP_COR_RACA','NO_MUNICIPIO_ESC',\n",
